        <jsScript_script>//Script here



var v_app_key = getVariable("API_APP_KEY", ""); 
var v_app_secret = getVariable("API_APP_SECRET", "");
var v_pagina = getVariable("contador", "1");


var requisicao = {
  "call": "ListarMovimentos",
  "app_key":v_app_key,
  "app_secret":v_app_secret,
	"param": [
    {
      "nPagina":1,
      "nRegPorPagina": 500
    
    }
  ]
};

// Converte o objeto em uma string no formato JSON.
// Esta string será colocada em um novo campo de saída chamado 'request_body'.
var request_body = JSON.stringify(requisicao);
</jsScript_script>
