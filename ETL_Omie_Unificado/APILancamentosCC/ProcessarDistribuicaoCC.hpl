<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>ProcessarDistribuicaoCC</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop> <from>Ler JSON Pai</from> <to>Parse JSON</to> <enabled>Y</enabled> </hop>
    <hop> <from>Parse JSON</from> <to>Gravar Filha</to> <enabled>Y</enabled> </hop>
  </order>
  <transform>
    <name>Ler JSON Pai</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <sql>SELECT id_empresa, nCodLanc, json_distribuicao
FROM staging.stg_fato_lancamentos_cc
WHERE json_distribuicao IS NOT NULL AND length(json_distribuicao) > 2</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Parse JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>cCodDep</name>
        <path>$.*.cCodDep</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>cDesDep</name>
        <path>$.*.cDesDep</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>nPerDep</name>
        <path>$.*.nPerDep</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>nValDep</name>
        <path>$.*.nValDep</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <valueField>json_distribuicao</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <attributes/>
    <GUI>
      <xloc>300</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Gravar Filha</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <schema>staging</schema>
    <table>stg_fato_lancamentos_cc_departamentos</table>
    <commit>1000</commit>
    <truncate>N</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>Y</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <fields>
      <field>
        <column_name>id_empresa</column_name>
        <stream_name>id_empresa</stream_name>
      </field>
      <field>
        <column_name>nCodLanc</column_name>
        <stream_name>nCodLanc</stream_name>
      </field>
      <field>
        <column_name>cCodDep</column_name>
        <stream_name>cCodDep</stream_name>
      </field>
      <field>
        <column_name>cDesDep</column_name>
        <stream_name>cDesDep</stream_name>
      </field>
      <field>
        <column_name>nPerDep</column_name>
        <stream_name>nPerDep</stream_name>
      </field>
      <field>
        <column_name>nValDep</column_name>
        <stream_name>nValDep</stream_name>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>500</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>