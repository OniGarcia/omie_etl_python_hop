  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Parametros API</from>
      <to>REST Client</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>REST Client</from>
      <to>Ler Total Paginas</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Ler Total Paginas</from>
      <to>Calcular Clones</to>
      <enabled>Y</enabled>
