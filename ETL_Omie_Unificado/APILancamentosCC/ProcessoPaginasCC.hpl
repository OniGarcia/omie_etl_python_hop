  <transform>
    <name>Parametros API</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var v_app_key = getVariable("VAR_OMIE_KEY", "");
var v_app_secret = getVariable("VAR_OMIE_SECRET", "");

var requisicao = {
  "call": "ListarLancCC",
  "app_key": v_app_key,
  "app_secret": v_app_secret,
  "param": [
    {
      "nPagina": 1,
      "nRegPorPagina": 20
    }
  ]
};

var request_body = JSON.stringify(requisicao);
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>request_body</name>
        <rename>request_body</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>REST Client</name>
