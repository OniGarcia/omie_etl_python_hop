  <transform>
    <name>Calcular Clones</name>
    <type>ScriptValueMod</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var clones = total_de_paginas - 1;
if (clones &lt; 0) {
	clones = 0;
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>clones</name>
        <rename>clones</rename>
        <type>Integer</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>N</replace>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>700</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Clone Row</name>
    <type>CloneRow</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
