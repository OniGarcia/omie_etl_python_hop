<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>ProcessarCategoriasCC</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description/>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user/>
    <created_date>2026/01/11 22:06:05.800</created_date>
    <modified_user/>
    <modified_date>2026/01/11 22:06:05.800</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Ler JSON Pai</from>
      <to>Parse JSON</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse JSON</from>
      <to>Gravar Filha</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Gravar Filha</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>1000</commit>
    <connection>Stg_Omie_Generic</connection>
    <fields>
      <field>
        <column_name>id_empresa</column_name>
        <stream_name>id_empresa</stream_name>
      </field>
      <field>
        <column_name>nCodLanc</column_name>
        <stream_name>nCodLanc</stream_name>
      </field>
      <field>
        <column_name>codigo_categoria</column_name>
        <stream_name>codigo_categoria</stream_name>
      </field>
      <field>
        <column_name>percentual</column_name>
        <stream_name>percentual</stream_name>
      </field>
      <field>
        <column_name>valor</column_name>
        <stream_name>valor</stream_name>
      </field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>staging</schema>
    <specify_fields>Y</specify_fields>
    <table>stg_fato_lancamentos_cc_categorias</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>500</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Ler JSON Pai</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT id_empresa, nCodLanc, json_categorias
FROM staging.stg_fato_lancamentos_cc
WHERE json_categorias IS NOT NULL AND length(json_categorias) > 2</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>100</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Parse JSON</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>codigo_categoria</name>
        <path>$.*.cCodCateg</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>percentual</name>
        <path>$.*.nPercCateg</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>valor</name>
        <path>$.*.nValor</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <valueField>json_categorias</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <attributes/>
