    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>
var v_app_key = getVariable("VAR_OMIE_KEY", "");
var v_app_secret = getVariable("VAR_OMIE_SECRET", "");
var v_pagina = getVariable("PAGINA_ATUAL", "1")

var requisicao = {
  "call": "ListarLancCC",
  "app_key": v_app_key,
  "app_secret": v_app_secret,
  "param": [
    {
      "nPagina":parseInt(v_pagina),
      "nRegPorPagina": 20
    }
  ]
};

var request_body = JSON.stringify(requisicao);
        </jsScript_script>
      </jsScript>
    </jsScripts>
