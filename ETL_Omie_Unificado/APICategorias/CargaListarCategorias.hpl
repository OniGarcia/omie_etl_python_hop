      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//Script here
// Cria um objeto JavaScript com a estrutura da requisição.
// A função getVariable() busca os parâmetros definidos na pipeline ou no workflow pai.
var v_app_key = getVariable("VAR_OMIE_KEY", "");
var v_app_secret = getVariable("VAR_OMIE_SECRET", "");
var requisicao = {
 "call": "ListarCategorias",
 "app_key":v_app_key,
 "app_secret":v_app_secret,
 "param": [
   {
     "pagina":parseInt(getVariable("PAGINA_ATUAL", 1)),
     "registros_por_pagina": 500,
     "apenas_importado_api": "N"
   }
 ]
};
// Converte o objeto em uma string no formato JSON.
// Esta string será colocada em um novo campo de saída chamado 'request_body'.
var request_body = JSON.stringify(requisicao);
</jsScript_script>
      </jsScript>
    </jsScripts>
