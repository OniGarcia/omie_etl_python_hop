        <jsScript_type>0</jsScript_type>
        <jsScript_name>Script 1</jsScript_name>
        <jsScript_script>//// Busca as credenciais globais
var v_app_key = getVariable("VAR_OMIE_KEY", "");
var v_app_secret = getVariable("VAR_OMIE_SECRET", "");
var requisicao = {
  "call": "ListarContasPagar",
  "app_key": v_app_key,
  "app_secret": v_app_secret,
  "param": [
    {
      "pagina": 1,
      "registros_por_pagina": 50, 
      "apenas_importado_api": "N"
    }
  ]
};

var request_body = JSON.stringify(requisicao);</jsScript_script>
      </jsScript>
