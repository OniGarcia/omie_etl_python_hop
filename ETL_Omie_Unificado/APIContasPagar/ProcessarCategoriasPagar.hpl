<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>ProcessarCategoriasPagar</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Processa o JSON de categorias do Contas a Pagar</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/16 18:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/16 18:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Ler JSON Categorias</from>
      <to>Parse JSON Categorias</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Parse JSON Categorias</from>
      <to>Gravar Categorias</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Ler JSON Categorias</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  id_empresa,
  codigo_lancamento_omie,
  json_categorias
FROM staging.stg_fato_contas_pagar
WHERE json_categorias IS NOT NULL
  AND length(json_categorias) > 2</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>200</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Parse JSON Categorias</name>
    <type>JsonInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <include>N</include>
    <include_field/>
    <rownum>N</rownum>
    <addresultfile>N</addresultfile>
    <readurl>N</readurl>
    <removeSourceField>N</removeSourceField>
    <IsIgnoreEmptyFile>N</IsIgnoreEmptyFile>
    <doNotFailIfNoFile>Y</doNotFailIfNoFile>
    <ignoreMissingPath>Y</ignoreMissingPath>
    <defaultPathLeafToNull>Y</defaultPathLeafToNull>
    <rownum_field/>
    <file>
      <name/>
      <filemask/>
      <exclude_filemask/>
      <file_required>N</file_required>
      <include_subfolders>N</include_subfolders>
    </file>
    <fields>
      <field>
        <name>codigo_categoria</name>
        <path>$.*.codigo_categoria</path>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>percentual</name>
        <path>$.*.percentual</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
      <field>
        <name>valor</name>
        <path>$.*.valor</path>
        <type>Number</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <repeat>N</repeat>
      </field>
    </fields>
    <limit>0</limit>
    <IsInFields>Y</IsInFields>
    <IsAFile>N</IsAFile>
    <valueField>json_categorias</valueField>
    <shortFileFieldName/>
    <pathFieldName/>
    <hiddenFieldName/>
    <lastModificationTimeFieldName/>
    <uriNameFieldName/>
    <rootUriNameFieldName/>
    <extensionFieldName/>
    <sizeFieldName/>
    <attributes/>
    <GUI>
      <xloc>400</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Gravar Categorias</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <commit>1000</commit>
    <connection>Stg_Omie_Generic</connection>
    <fields>
      <field>
        <column_name>id_empresa</column_name>
        <stream_name>id_empresa</stream_name>
      </field>
      <field>
        <column_name>codigo_lancamento_omie</column_name>
        <stream_name>codigo_lancamento_omie</stream_name>
      </field>
      <field>
        <column_name>codigo_categoria</column_name>
        <stream_name>codigo_categoria</stream_name>
      </field>
      <field>
        <column_name>percentual</column_name>
        <stream_name>percentual</stream_name>
      </field>
      <field>
        <column_name>valor</column_name>
        <stream_name>valor</stream_name>
      </field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_field/>
    <return_keys>N</return_keys>
    <schema>staging</schema>
    <specify_fields>Y</specify_fields>
    <table>stg_fato_contas_pagar_categorias</table>
    <tablename_field/>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI>
      <xloc>600</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
