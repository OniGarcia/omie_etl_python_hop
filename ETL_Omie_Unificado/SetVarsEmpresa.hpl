<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>SetVarsEmpresa</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Bridge: traduz parâmetros P_* recebidos pelo master em variáveis VAR_* no escopo root, para que todas as 24 leaf pipelines leiam as credenciais corretas da empresa</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>claude</created_user>
    <created_date>2026/06/01 00:00:00.000</created_date>
    <modified_user>claude</modified_user>
    <modified_date>2026/06/01 00:00:00.000</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Generate Row</from>
      <to>Get Parameters</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Get Parameters</from>
      <to>Set Variables</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Generate Row</name>
    <type>RowGenerator</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
</fields>
    <interval_in_ms>5000</interval_in_ms>
    <last_time_field>FiveSecondsAgo</last_time_field>
    <limit>1</limit>
    <never_ending>N</never_ending>
    <row_time_field>now</row_time_field>
    <attributes/>
    <GUI>
      <xloc>160</xloc>
      <yloc>176</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Get Parameters</name>
    <type>GetVariable</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <length>-1</length>
        <name>p_api_key</name>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <type>String</type>
        <variable>${P_API_KEY}</variable>
      </field>
      <field>
        <length>-1</length>
        <name>p_api_secret</name>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <type>String</type>
        <variable>${P_API_SECRET}</variable>
      </field>
      <field>
        <length>-1</length>
        <name>p_id_empresa</name>
        <precision>-1</precision>
        <trim_type>none</trim_type>
        <type>String</type>
        <variable>${P_ID_EMPRESA}</variable>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>352</xloc>
      <yloc>176</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Set Variables</name>
    <type>SetVariable</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field>
        <field_name>p_api_key</field_name>
        <variable_type>ROOT_WORKFLOW</variable_type>
        <variable_name>VAR_OMIE_KEY</variable_name>
        <default_value/>
      </field>
      <field>
        <field_name>p_api_secret</field_name>
        <variable_type>ROOT_WORKFLOW</variable_type>
        <variable_name>VAR_OMIE_SECRET</variable_name>
        <default_value/>
      </field>
      <field>
        <field_name>p_id_empresa</field_name>
        <variable_type>ROOT_WORKFLOW</variable_type>
        <variable_name>VAR_ID_EMPRESA</variable_name>
        <default_value/>
      </field>
    </fields>
    <attributes/>
    <GUI>
      <xloc>544</xloc>
      <yloc>176</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
