<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>CargaDimCategorias</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga da Dimensão Categorias (SCD2)</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit/>
    <created_user/>
    <created_date>2026/01/12 21:16:33.660</created_date>
    <modified_user/>
    <modified_date>2026/01/12 21:16:33.660</modified_date>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop>
      <from>Ler Stg Categorias</from>
      <to>Dimension lookup/update</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Dimension lookup/update</name>
    <type>DimensionLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <cache_size>5000</cache_size>
    <commit>100</commit>
    <connection>Stg_Omie_Generic</connection>
    <fields>
      <date>
        <from>date_from</from>
        <to>date_to</to>
      </date>
      <field>
        <lookup>descricao_original</lookup>
        <name>descricao</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>descricao_bi</lookup>
        <name>descricao</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>categoria_superior</lookup>
        <name>categoria_superior</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>natureza</lookup>
        <name>natureza</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>tipo_conta</lookup>
        <name>tipo_categoria</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>e_totalizadora</lookup>
        <name>totalizadora</name>
        <update>Insert</update>
      </field>
      <field>
        <lookup>e_inativa</lookup>
        <name>conta_inativa</name>
        <update>Insert</update>
      </field>
      <key>
        <lookup>id_empresa</lookup>
        <name>id_empresa</name>
      </key>
      <key>
        <lookup>codigo_categoria</lookup>
        <name>codigo</name>
      </key>
      <return>
        <creation_method>tablemax</creation_method>
        <name>sk_categoria</name>
        <version>version</version>
      </return>
    </fields>
    <max_year>2199</max_year>
    <min_year>1900</min_year>
    <preload_cache>N</preload_cache>
    <schema>staging</schema>
    <table>dim_categorias</table>
    <update>Y</update>
    <useBatch>N</useBatch>
    <use_start_date_alternative>N</use_start_date_alternative>
    <attributes/>
    <GUI>
      <xloc>450</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform>
    <name>Ler Stg Categorias</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT
  id_empresa,
  codigo,
  descricao,
  categoria_superior,
  natureza,
  tipo_categoria,
  totalizadora,
  conta_inativa
FROM stg_cad_categorias
WHERE descricao NOT LIKE '%&lt;Disponível&gt;%' -- Filtra as categorias disponíveis/vazias
ORDER BY id_empresa, codigo</sql>
    <variables_active>N</variables_active>
    <attributes/>
    <GUI>
      <xloc>200</xloc>
      <yloc>100</yloc>
    </GUI>
  </transform>
  <transform_error_handling>
  </transform_error_handling>
  <attributes/>
</pipeline>
