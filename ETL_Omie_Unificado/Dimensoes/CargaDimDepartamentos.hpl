<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>CargaDimDepartamentos</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Carga da Dimensão Departamentos (SCD2)</description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters>
    </parameters>
  </info>
  <notepads>
  </notepads>
  <order>
    <hop> <from>Ler Stg Departamentos</from> <to>Dimension lookup/update</to> <enabled>Y</enabled> </hop>
  </order>
  <transform>
    <name>Ler Stg Departamentos</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <sql>SELECT 
  id_empresa,
  codigo, 
  descricao,
  estrutura,
  inativo
FROM stg_cad_departamentos
ORDER BY id_empresa, codigo</sql>
    <limit>0</limit>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <GUI> <xloc>200</xloc> <yloc>100</yloc> </GUI>
  </transform>
  <transform>
    <name>Dimension lookup/update</name>
    <type>DimensionLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Stg_Omie_Generic</connection>
    <schema>staging</schema>
    <table>dim_departamentos</table>
    <commit>100</commit>
    <update>Y</update>
    <fields>
      <key>
        <name>id_empresa</name>
        <lookup>id_empresa</lookup>
      </key>
      <key>
        <name>codigo</name>
        <lookup>codigo_departamento</lookup>
      </key>
      <date>
        <name/>
        <from>date_from</from>
        <to>date_to</to>
      </date>
      <field>
        <name>descricao</name>
        <lookup>descricao_original</lookup>
        <update>Insert</update>
      </field>
      <field>
        <name>descricao</name>
        <lookup>descricao_bi</lookup>
        <update>Insert</update>
      </field>
      <field>
        <name>estrutura</name>
        <lookup>estrutura</lookup>
        <update>Insert</update>
      </field>
      <field>
        <name>inativo</name>
        <lookup>e_inativo</lookup>
        <update>Insert</update>
      </field>
      <return>
        <name>sk_departamento</name>
        <rename/>
        <creation_method>tablemax</creation_method>
        <use_autoinc>N</use_autoinc>
        <version>version</version>
      </return>
    </fields>
    <min_year>1900</min_year>
    <max_year>2199</max_year>
    <cache_size>5000</cache_size>
    <preload_cache>N</preload_cache>
    <useBatch>N</useBatch>
    <GUI> <xloc>450</xloc> <yloc>100</yloc> </GUI>
  </transform>
</pipeline>