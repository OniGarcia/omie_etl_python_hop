        <jsScript_script>var v_app_key = getVariable("VAR_OMIE_KEY", "");
var v_app_secret = getVariable("VAR_OMIE_SECRET", "");
var requisicao = {
  "call": "ListarClientes",
  "app_key": v_app_key,
  "app_secret": v_app_secret,
  "param": [
    {
      "pagina": parseInt(getVariable("PAGINA_ATUAL", 1)),
      "registros_por_pagina": 50,
      "apenas_importado_api": "N"
    }
  ]
};
var request_body = JSON.stringify(requisicao);

</jsScript_script>
