<?xml version="1.0" encoding="UTF-8"?>
<workflow>
  <name>wf_master_extracao_completa</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>Master workflow que executa todos os 8 workflows de extração em sequência para uma empresa</description>
  <extended_description>
    Orquestra a extração completa de dados da API Omie para uma empresa específica.
    Parâmetros esperados: P_API_KEY, P_API_SECRET, P_ID_EMPRESA
    Se não passados, usa os valores padrão de project variables.
  </extended_description>
  <workflow_version/>
  <workflow_status>0</workflow_status>
  <created_user>claude</created_user>
  <created_date>2026/04/16 00:00:00.000</created_date>
  <modified_user>claude</modified_user>
  <modified_date>2026/06/01 00:00:00.000</modified_date>
  <parameters>
    <parameter>
      <name>P_API_KEY</name>
      <default_value>${VAR_OMIE_KEY}</default_value>
      <description>App Key da Omie (vem de config.empresas)</description>
    </parameter>
    <parameter>
      <name>P_API_SECRET</name>
      <default_value>${VAR_OMIE_SECRET}</default_value>
      <description>App Secret da Omie (vem de config.empresas)</description>
    </parameter>
    <parameter>
      <name>P_ID_EMPRESA</name>
      <default_value>${VAR_ID_EMPRESA}</default_value>
      <description>ID da empresa (vem de config.empresas)</description>
    </parameter>
  </parameters>
  <actions>
    <action>
      <name>Start</name>
      <description>Ponto de partida do workflow</description>
      <type>SPECIAL</type>
      <attributes/>
      <DayOfMonth>1</DayOfMonth>
      <doNotWaitOnFirstExecution>N</doNotWaitOnFirstExecution>
      <hour>12</hour>
      <intervalMinutes>60</intervalMinutes>
      <intervalSeconds>0</intervalSeconds>
      <minutes>0</minutes>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <weekDay>1</weekDay>
      <parallel>N</parallel>
      <xloc>0</xloc>
      <yloc>80</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>SetVarsEmpresa</name>
      <description>Bridge: propaga P_API_KEY/P_API_SECRET/P_ID_EMPRESA como VAR_* no escopo root para todas as leaf pipelines</description>
      <type>PIPELINE</type>
      <attributes/>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <clear_files>N</clear_files>
      <clear_rows>N</clear_rows>
      <create_parent_folder>N</create_parent_folder>
      <exec_per_row>N</exec_per_row>
      <filename>${PROJECT_HOME}/SetVarsEmpresa.hpl</filename>
      <logext/>
      <logfile/>
      <loglevel>Basic</loglevel>
      <parameters>
        <parameter>
          <name>P_API_KEY</name>
          <stream_name/>
          <value>${P_API_KEY}</value>
        </parameter>
        <parameter>
          <name>P_API_SECRET</name>
          <stream_name/>
          <value>${P_API_SECRET}</value>
        </parameter>
        <parameter>
          <name>P_ID_EMPRESA</name>
          <stream_name/>
          <value>${P_ID_EMPRESA}</value>
        </parameter>
        <pass_all_parameters>N</pass_all_parameters>
      </parameters>
      <params_from_previous>N</params_from_previous>
      <run_configuration>local</run_configuration>
      <set_append_logfile>N</set_append_logfile>
      <set_logfile>N</set_logfile>
      <wait_until_finished>Y</wait_until_finished>
      <parallel>N</parallel>
      <xloc>144</xloc>
      <yloc>80</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>LogInicio</name>
      <description>Registra início da extração desta empresa no log de auditoria</description>
      <type>SQL</type>
      <attributes/>
      <connection>Stg_Omie_Generic</connection>
      <sendOneStatement>Y</sendOneStatement>
      <sql>INSERT INTO config.etl_execucao(id_empresa, entidade, status, dt_inicio) VALUES (${P_ID_EMPRESA}, 'LOTE', 'INICIADO', now())</sql>
      <sqlfromfile>N</sqlfromfile>
      <useVariableSubstitution>Y</useVariableSubstitution>
      <parallel>N</parallel>
      <xloc>304</xloc>
      <yloc>80</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>wf_extracao_categorias</name>
      <description>Extrai categorias (plano de contas) da API Omie</description>
      <type>WORKFLOW</type>
      <attributes/>
      <add_date>N</add_date>
      <add_time>N</add_time>
      <create_parent_folder>N</create_parent_folder>
      <exec_per_row>N</exec_per_row>
      <filename>${PROJECT_HOME}/APICategorias/wf_extracao_categorias.hwf</filename>
      <loglevel>Basic</loglevel>
      <parameters>
        <parameter>
          <name>P_API_KEY</name>
          <value>${P_API_KEY}</value>
        </parameter>
        <parameter>
          <name>P_API_SECRET</name>
          <value>${P_API_SECRET}</value>
        </parameter>
        <parameter>
          <name>P_ID_EMPRESA</name>
          <value>${P_ID_EMPRESA}</value>
        </parameter>
        <pass_all_parameters>N</pass_all_parameters>
      </parameters>
      <params_from_previous>N</params_from_previous>
      <run_configuration>local</run_configuration>
      <set_append_logfile>N</set_append_logfile>
      <set_logfile>N</set_logfile>
      <wait_until_finished>Y</wait_until_finished>
      <parallel>N</parallel>
      <xloc>464</xloc>
      <yloc>80</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>wf_extracao_departamentos</name>
      <description>Extrai departamentos da API Omie</description>
