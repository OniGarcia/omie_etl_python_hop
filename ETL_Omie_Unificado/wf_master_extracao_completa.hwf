      </parameters>
      <params_from_previous>N</params_from_previous>
      <run_configuration>local</run_configuration>
      <set_append_logfile>N</set_append_logfile>
      <set_logfile>N</set_logfile>
      <wait_until_finished>Y</wait_until_finished>
      <parallel>N</parallel>
      <xloc>880</xloc>
      <yloc>208</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>validar_cc_nao_vazia</name>
      <description>Guardrail: aborta a carga do DW se stg_fato_lancamentos_cc estiver vazia (linhas reais) para a empresa</description>
      <type>SQL</type>
      <attributes/>
      <connection>Stg_Omie_Generic</connection>
      <sendOneStatement>Y</sendOneStatement>
      <sql>SELECT CAST(CASE WHEN COUNT(*) = 0 THEN 'ABORT_stg_fato_lancamentos_cc_vazia_empresa_${VAR_ID_EMPRESA}' ELSE '1' END AS integer) FROM staging.stg_fato_lancamentos_cc WHERE id_empresa = ${VAR_ID_EMPRESA} AND ncodlanc IS NOT NULL</sql>
      <sqlfromfile>N</sqlfromfile>
      <useVariableSubstitution>Y</useVariableSubstitution>
      <parallel>N</parallel>
      <xloc>1088</xloc>
      <yloc>208</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>wf_carga_dw</name>
      <description>Executa a procedure de carga do DW (dimensões + fact_movimento_financeiro)</description>
      <type>SQL</type>
      <attributes/>
      <connection>Stg_Omie_Generic</connection>
      <sendOneStatement>Y</sendOneStatement>
      <sql>CALL dw.sp_load_fact_movimento_financeiro();</sql>
      <sqlfromfile>N</sqlfromfile>
      <useVariableSubstitution>N</useVariableSubstitution>
      <parallel>N</parallel>
      <xloc>96</xloc>
      <yloc>336</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>LogFim</name>
      <description>Registra fim com sucesso da extração desta empresa no log de auditoria</description>
      <type>SQL</type>
      <attributes/>
      <connection>Stg_Omie_Generic</connection>
      <sendOneStatement>Y</sendOneStatement>
      <sql>INSERT INTO config.etl_execucao(id_empresa, entidade, status, dt_inicio, dt_fim) VALUES (${P_ID_EMPRESA}, 'LOTE', 'SUCESSO', now(), now())</sql>
      <sqlfromfile>N</sqlfromfile>
      <useVariableSubstitution>Y</useVariableSubstitution>
      <parallel>N</parallel>
      <xloc>304</xloc>
      <yloc>336</yloc>
      <attributes_hac/>
    </action>
    <action>
      <name>Success</name>
      <description>Extração completada com sucesso</description>
      <type>SPECIAL</type>
      <attributes/>
      <DayOfMonth>1</DayOfMonth>
      <doNotWaitOnFirstExecution>N</doNotWaitOnFirstExecution>
      <hour>12</hour>
      <intervalMinutes>60</intervalMinutes>
      <intervalSeconds>0</intervalSeconds>
      <minutes>0</minutes>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <weekDay>1</weekDay>
      <parallel>N</parallel>
      <xloc>496</xloc>
      <yloc>336</yloc>
      <attributes_hac/>
    </action>
  </actions>
  <hops>
    <hop>
